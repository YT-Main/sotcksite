# Copy to `.env.local` — get a key at https://twelvedata.com/pricing

TWELVE_DATA_API_KEY=

# If server-side requests fail with UNABLE_TO_GET_ISSUER_CERT_LOCALLY, Node/OpenSSL cannot
# find a trusted CA bundle. On macOS with Homebrew Node, uncomment one line below (same
# file Next.js reads for env). Then restart `pnpm dev` / `npm run dev`.
# Apple Silicon Homebrew:
# SSL_CERT_FILE=/opt/homebrew/etc/ca-certificates/cert.pem
# Intel Homebrew:
# SSL_CERT_FILE=/usr/local/etc/ca-certificates/cert.pem
# Refresh roots if needed: `brew reinstall ca-certificates`
